// Test interface functors: an interface that imports another interface.
module T044 where

interface submodule I where
  type n : #

// An interface functor: an interface with `import interface`
interface submodule J where
  import interface submodule I

  type m : #
  type constraint (m <= n)
  f : [m] -> [n]

// Instantiating J produces a normal interface
interface submodule K = submodule J where
  type n = 8

// Use the resulting interface in a functor
submodule F where
  import interface submodule K
  // This requires the constraint m <= 8 to type-check
  g : [m] -> [8]
  g x = zext x

// Instantiate F with a concrete implementation
submodule Impl where
  type m = 4
  f x = zext x

submodule G = submodule F { submodule Impl }

import submodule G as G

test = G::g 0xA == 0x0A
